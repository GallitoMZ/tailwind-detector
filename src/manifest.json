{
  "manifest_version": 3,
  "name": "Tailwind Detector",
  "version": "1.0.1",
  "description": "Detecta automáticamente si un sitio usa Tailwind CSS, muestra la versión y enciende el icono en tiempo real.",
  "author": "Gato Salvaje",
  "minimum_chrome_version": "102",
  "permissions": ["activeTab", "scripting", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-inactivo-16.png",
      "48": "icons/icon-inactivo-48.png",
      "128": "icons/icon-inactivo-128.png"
    },
    "default_title": "Tailwind Detector"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon-inactivo-16.png",
    "48": "icons/icon-inactivo-48.png",
    "128": "icons/icon-inactivo-128.png"
  }
}